<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>at.hannos.ai-agent-cli-bridge</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>AI Agent CLI Bridge</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>hannos</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Enter short description for your plugin here.<br>
        <em>most HTML tags may be used</em>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                id="at.hannos.aiagentclibridge.settings"
                displayName="AI Agent CLI Bridge"
                instance="at.hannos.aiagentclibridge.config.AiAgentCliBridgeConfigurable"/>
        <intentionAction>
            <className>at.hannos.aiagentclibridge.action.SendErrorToTerminalAction</className>
            <category>AI Agent CLI Bridge</category>
            <skipBeforeAfter>true</skipBeforeAfter>
        </intentionAction>
    </extensions>

    <actions>
        <action id="at.hannos.aiagentclibridge.action.CreateConfiguredTerminalSessionAction"
                class="at.hannos.aiagentclibridge.action.CreateConfiguredTerminalSessionAction"
                text="Open Configured AI Terminal"
                description="Open a new terminal tab and launch configured program"
                icon="/icons/buttonIcon.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
        </action>
        <action id="at.hannos.aiagentclibridge.action.SendSelectionToTerminalAction"
                class="at.hannos.aiagentclibridge.action.SendSelectionToTerminalAction"
                text="Send Selection to AI Tool"
                description="Send selected editor text to AI tool"
                icon="at.hannos.aiagentclibridge.MyIcons.MyIcon"
        >
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action id="at.hannos.aiagentclibridge.action.SendFileReferenceToTerminalAction"
                class="at.hannos.aiagentclibridge.action.SendFileReferenceToTerminalAction"
                text="Send File Reference to AI Tool"
                description="Send selected file or folder reference to AI Tool"
                icon="at.hannos.aiagentclibridge.MyIcons.MyIcon"
        >
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="at.hannos.aiagentclibridge.action.AiReviewAction"
                class="at.hannos.aiagentclibridge.action.AiReviewAction"
                text="AI Review"
                description="Review the current changes"
                icon="at.hannos.aiagentclibridge.MyIcons.MyIcon">
            <add-to-group group-id="ChangesViewToolbar" anchor="last"/>
        </action>
    </actions>
</idea-plugin>